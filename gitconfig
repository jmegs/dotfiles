[user]
  name = John Meguerian
  email = johnmeguerian@gmail.com

[alias]
  aa = add --all
  c = commit
  cm = commit -m
  cma = commit --amend --no-edit
  st = status
  br = branch
	oops = !git reset --hard && git clean -dfi
	lg = log --oneline --decorate -20
	lga = log --oneline --decorate --graph --all -20
  mib = !git switch main && git merge - --ff-only

[branch]
  sort = -committerdate

[color]
	diff = auto
	status = auto
	branch = auto
	ui = true

[core]
	attributesfile = ~/.gitattributes
	excludesfile = ~/.gitignore
	pager = diff-so-fancy | less -RFX
	autocrlf = input
	editor = nvim

[delta]
  navigate = true

[diff]
  algorithm = histogram

[github]
  user = jmegs

[interactive]
  diffFilter = delta --color-only

[merge]
  conflictstyle = zdiff3

[pull]
  rebase = true

[push]
  autoSetupRemote = true
  default = current
  followTags = true

[fetch]
	prune = true

[rebase]
  # https://thoughtbot.com/blog/autosquashing-git-commits
  autosquash = true
  # https://jvns.ca/blog/2024/02/16/popular-git-config-options/
  autostash = true

[diff]
  colorMoved = zebra

[init]
  defaultBranch = main

