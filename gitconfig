[user]
  name = John Meguerian
  email = johnmeguerian@gmail.com

# Work repos kept under ~/Developer/sqsp/ use the work identity.
[includeIf "gitdir:~/Developer/sqsp/"]
  path = ~/.gitconfig-work

# Backstop: any repo whose remote points at the sqsp GitHub org, wherever it lives.
[includeIf "hasconfig:remote.*.url:**sqsp/**"]
  path = ~/.gitconfig-work

[alias]
  aa = add --all
  c = commit
  cm = commit -m
  cma = commit --amend --no-edit
  st = status
  br = branch
	oops = !git reset --hard && git clean -dfi
	lg = log --oneline --decorate --pretty=nice 
	lga = log --oneline --decorate --graph --all
  mib = !git switch main && git merge - --ff-only
  up = push -u origin HEAD

[branch]
  sort = -committerdate

[color]
	diff = auto
	status = auto
	branch = auto
	ui = true

[core]
	attributesfile = ~/.gitattributes
	excludesfile = ~/.gitignore
	pager = delta
	autocrlf = input
	editor = nvim

[delta]
  navigate = true

[diff]
  algorithm = histogram

[github]
  user = jmegs

[interactive]
  diffFilter = delta --color-only

[merge]
  conflictstyle = zdiff3

[pull]
  rebase = true

[push]
  default = current
  followTags = true

[pretty]
  nice = format:%C(auto)%h %C(blue)%>(15,trunc)%cr %C(green)%<(15,trunc)%aN%C(auto)%d %Creset%s
  
[fetch]
	prune = true

[rebase]
  # https://thoughtbot.com/blog/autosquashing-git-commits
  autosquash = true
  # https://jvns.ca/blog/2024/02/16/popular-git-config-options/
  autostash = true

[diff]
  colorMoved = zebra

[init]
  defaultBranch = main

[http "https://appspace.squarespace.net/"]
	sslCAInfo = /Users/jmeguerian/.sqsp/ca_bundle.pem

[credential "https://appspace.squarespace.net"]
	helper = osxkeychain
